<Window
    x:Class="Lesson2.Example1.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Lesson2.Example1"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock HorizontalAlignment="Center" Text="Работа с процессом" />
            <StackPanel Orientation="Horizontal">
                <Button Width="150" Content="Создать процесс" Click="CreateProcess_Button_Click" />
                <Button Width="150" Content="Убить процесс" Click="KillProcess_Button_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
